# Backend Environment Variables
# Copy this file to .env and fill in your values

# API Metadata
PROJECT_NAME=Autonomous Research Agent
PROJECT_VERSION=0.1.0
API_V1_STR=/api/v1

# OpenRouter Configuration (OpenAI-compatible endpoint)
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=openrouter/free
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# LLM Configuration
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=0

# Logging
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./storage/db/research_agent.db
REPORTS_DIR=storage/reports

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0)(:\\d+)?$|^https://([a-zA-Z0-9-]+\\.)*vercel\\.app$
